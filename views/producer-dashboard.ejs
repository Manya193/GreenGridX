<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Dashboard</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body {
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
  display: flex;
  background: #f4f7f6;  
}

/* SIDEBAR */
.sidebar {
  width: 260px;
  height: 100vh;
  background: #0f3d4c;
  color: white;
  padding: 20px;
  position: fixed;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
}

.sidebar-top a {
  display: block;
  color: #cfe8e5;
  text-decoration: none;
  margin: 12px 0;
  padding-bottom: 10px;
}

.sidebar-top a:hover {
  color: white;
}

.logout-box {
  background: rgba(255,255,255,0.08);
  padding: 12px;
  border-radius: 10px;
  text-align: center;
}

.logout-box a {
  color: white;
  text-decoration: none;
}

/* MAIN */
.main {
  margin-left: 260px;
  padding: 10px 30px;
  width: 100%;
}

/* HEADER */
.header p {
  color: #666;
}

/* STATS */
.top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 30px;
   background: linear-gradient(135deg, #f0fffb, #e6f7f3);
  box-shadow: 0 6px 18px rgba(0,0,0,0.06);
  padding-left: 15px;
  padding-right: 15px;
}

.stats {
  display: flex;
  gap: 50px;
}

.stat-item h3 {
  font-size: 14px;
  color: #666;
}

.stat-item p {
  font-size: 22px;
  font-weight: bold;
}

/* PROGRESS */
.progress-box {
  width: 250px;
}

.progress-bar {
  background: #ddd;
  border-radius: 10px;
  overflow: hidden;
}

.progress-fill {
  background: #0d6b5c;
  color: white;
  text-align: center;
  font-size: 12px;
  padding: 4px;
}

/* AI */
.ai-box {
  margin-top: 30px;
  padding: 20px;
  background: white;
  border-radius: 10px;
   background: linear-gradient(135deg, #f0fffb, #e6f7f3);
  box-shadow: 0 6px 18px rgba(0,0,0,0.06);
}

/* CHARTS */
.charts {
  display: flex;
  gap: 20px;
  margin-top: 30px;
}

.chart-box {
  flex: 1;
  background: white;
  padding: 15px;
  border-radius: 10px;
}

/* LISTINGS */
.cards-container {
  display: grid;
  grid-template-columns: repeat(auto-fit,minmax(200px,1fr));
  gap: 20px;
  margin-top: 15px;
}

.card {
  background: white;
  padding: 15px;
  border-radius: 10px;
}

canvas {
  height: 200px !important;
}
.add-btn {
  margin-top: 25px;
  text-align: center;
}

.add-energy-btn {
  padding: 12px 22px;
  border-radius: 25px;
  border: none;
  background: #0d6b5c;
  color: white;
  font-size: 14px;
  cursor: pointer;
  transition: 0.3s ease;
}

.add-energy-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 12px rgba(0,0,0,0.15);
}
/* MODAL BACKGROUND */
.energy-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(6px);
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

/* MODAL BOX */
.energy-modal-content {
  background: white;
  padding: 30px 50px 30px 30px;
  border-radius: 15px;
  width: 350px;
  position: relative;
  animation: popup 0.3s ease;
}

/* ANIMATION */
@keyframes popup {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

/* CLOSE BUTTON */
.close-btn {
  position: absolute;
  right: 15px;
  top: 10px;
  font-size: 22px;
  cursor: pointer;
}

/* INPUTS */
.energy-modal-content input,
.energy-modal-content select {
  width: 100%;
  padding: 10px;
  margin: 10px 0;
  border-radius: 8px;
  border: 1px solid #ccc;
}

/* BUTTON */
.submit-btn {
  width: 100%;
  padding: 10px;
  border-radius: 20px;
  border: none;
  background: #0d6b5c;
  color: white;
  cursor: pointer;
  margin-top: 10px;
}

.submit-btn:hover {
  box-shadow: 0 5px 12px rgba(0,0,0,0.2);
}
.chart-info {
  margin-top: 20px;
  padding: 6px 10px;
  font-size: 13px;
  color: #555;
  background: #f8f9fa;
  border-left: 3px solid #4fc3f7;
  border-radius: 6px;
  text-align: center;
}
.modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(15, 61, 76, 0.4);
  backdrop-filter: blur(4px);
  justify-content: center;
  align-items: center;
  z-index: 2000;
}

.modal-content {
  background: white;
  padding: 30px 25px;  
  width: 420px;
  max-height: 75%;
  overflow-y: auto;
  border-radius: 18px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.2);
}

/* PREMIUM CARD INSIDE MODAL */
.modal-card {
  background: #f9fdfc;
  border-left: 4px solid #0d6b5c;
  padding: 14px 16px;
  margin-bottom: 14px;   
  padding-bottom: 20px;
  border-radius: 10px;
}

.modal-card:hover {
  transform: translateX(4px);
  background: #eefaf7;
}

.modal-title {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 20px; 
  padding-bottom: 10px;  
}

.highlight {
  color: #0d6b5c;
  font-weight: bold;
}
</style>
</head>

<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <div class="sidebar-top">
    <h2>⚡ GreenGridX</h2>
    <a href="#" onclick="showDashboard()">🏠 Dashboard</a>
<a href="#" onclick="showListings()">📊 My Listings</a>
<a href="#" onclick="showTransactions()">💳 Transactions</a>
<a href="#" onclick="showCarbon()">🌱 Carbon Credits</a>
  </div>

  <div class="logout-box">
  <a href="/logout">🚪 Logout</a>
</div>
</div>

<!-- MAIN -->
<div class="main">

<div class="header">
  <h1>Welcome 👋</h1>
  <p>Manage your energy listings</p>
</div>

<!-- STATS + PROGRESS -->
<div class="top-row">

  <div class="stats">
    <div class="stat-item">
      <h3>Total Energy</h3>
      <p><%= totalEnergy || 0 %> kWh</p>
    </div>

    <div class="stat-item">
      <h3>Energy Sold</h3>
      <p><%= energySold || 0 %> kWh</p>
    </div>

    <div class="stat-item">
      <h3>Total Earnings</h3>
      <p>₹ <%= totalEarnings || 0 %></p>
    </div>
  </div>

  <!-- PROGRESS -->
  <div class="progress-box">

  <!-- ✅ TITLE FIX -->
  <p style="font-weight:500;">⚡ Energy Sold Progress</p>

  <div class="progress-bar">
    <div class="progress-fill"
      style="width:<%= totalEnergy ? (energySold/totalEnergy)*100 : 0 %>%;">
      
      <!-- ✅ KEEP % -->
      <%= totalEnergy ? Math.round((energySold/totalEnergy)*100) : 0 %>%

    </div>
  </div>

  
  <p style="font-size:12px; color:#555; margin-top:5px;">
    <%= energySold || 0 %> kWh sold out of <%= totalEnergy || 0 %> kWh
  </p>

</div>

</div>

<!-- AI -->
<div class="ai-box">
  <h3>🤖 AI Insights</h3>
 <p>Predicted Demand (<b><%= predictedTime %></b>): <b><%= predictedDemand %> kWh</b></p>
  <p>Recommended Price: <b>₹ <%= recommendedPrice %></b></p>
  <p>Best time to sell ⚡ : <b><%= predictedTime %></b></p>
</div>

<!-- CHARTS -->
<% if((totalEnergy||0)>0 || (energySold||0)>0){ %>

<div class="charts">

  <div class="chart-box">
  <h4>📊 Demand</h4>
  <canvas id="demandChart"></canvas>

  <div class="chart-info">
    📈 Shows predicted energy demand across different times of the day
  </div>
</div>

  <div class="chart-box">
  <h4>💰 Earnings</h4>
  <canvas id="earningsChart"></canvas>

  <div class="chart-info">
    💰 Shows your daily earnings (₹) based on energy sold throughout the week
  </div>
</div>

  <div class="chart-box">
  <h4>⚡ Distribution</h4>
  <canvas id="timeChart"></canvas>

  <div class="chart-info">
  <% if(morning === 0 && afternoon === 0 && evening === 0){ %>
    ⚠ No energy distribution available
  <% } else { %>
    ⚡ Shows how your available energy is distributed across morning, afternoon, and evening
  <% } %>
</div>
</div>

</div>

<% } else { %>
<p>No analytics available yet ⚡</p>
<% } %>

<!-- LISTINGS -->
<h2>Your Energy Listings</h2>

<% if(availableListings.length===0){ %>
<p>No energy listed yet ⚡</p>
<% } else { %>

<div class="cards-container">
<% availableListings.forEach(item=>{ %>
  <div class="card">
    <p><b>Energy:</b> <%= item.energyAmount %></p>
    <p><b>Price:</b> ₹ <%= item.price %></p>
    <p><b>Time:</b> <%= item.time %></p>
  </div>
<% }) %>
</div>

<% } %>

<div class="add-btn">
  <button class="add-energy-btn" onclick="openEnergyModal()">
    + Add Energy Listing
  </button>
</div>

</div>
<!-- ADD ENERGY MODAL -->
<div id="energyModal" class="energy-modal">

  <div class="energy-modal-content">

    <span class="close-btn" onclick="closeEnergyModal()">&times;</span>

    <h2>⚡ Add Energy</h2>

    <form action="/add-energy" method="POST">

      <input type="number" name="energyAmount" placeholder="Energy (kWh)" required>

      <input type="number" name="price" placeholder="Price per kWh (₹)" required>

      <input type="text" name="location" placeholder="Location" required>

      <select name="time" required>
        <option value="">Select Time</option>
        <option value="morning">Morning</option>
        <option value="afternoon">Afternoon</option>
        <option value="evening">Evening</option>
      </select>

      <button type="submit" class="submit-btn">Add Listing</button>

    </form>

  </div>

</div>
<!-- MODAL BACKGROUND -->
<div id="modal" class="modal">
  <div class="modal-content">
    <span class="close-btn" onclick="closeModal()">&times;</span>
    <div id="modal-body"></div>
  </div>
</div>

<!-- JS -->
<script>

const ctx1=document.getElementById('demandChart');
const ctx2=document.getElementById('earningsChart');
const ctx3=document.getElementById('timeChart');

// LINE
if(ctx1){
new Chart(ctx1,{
type:'line',
data:{
labels:['Morning','Afternoon','Evening'],
datasets:[{
  label:"Predicted Demand",
data:<%= JSON.stringify(demandData) %>,
borderColor:'#0d6b5c',
fill:true
}]
}
});
}

// BAR
// ✅ WEEKLY EARNINGS CHART

const earningsData = <%= JSON.stringify(weeklyEarnings || []) %>;

if (ctx2) {

  new Chart(ctx2, {
    type: 'bar',
    data: {
      labels: ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'],
      datasets: [{
        label: 'Earnings (₹)',
        data: earningsData,
        backgroundColor: '#4fc3f7'
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,

      plugins: {
        title: {
          display: true,
          text: '📊 Weekly Earnings'
        }
      },

      scales: {
        x: {
          title: {
            display: true,
            text: 'Days'
          }
        },
       y: {
  beginAtZero: true,
  suggestedMax: 300,
  ticks: {
    stepSize: 50,
    callback: function(value) {
      return "₹ " + value;
    }
  }
}
      }
    }
  });

}
// DOUGHNUT
if(ctx3){
new Chart(ctx3,{
type:'doughnut',
data:{
labels:['Morning','Afternoon','Evening'],
datasets:[{
data:[
<%= morning||0 %>,
<%= afternoon||0 %>,
<%= evening||0 %>
],
backgroundColor:['#4CAF50','#FFC107','#2196F3']
}]
},
options:{cutout:'70%'}
});
}

</script>
<script>

// ===== ENERGY MODAL =====
function openEnergyModal() {
  document.getElementById("energyModal").style.display = "flex";
}

function closeEnergyModal() {
  document.getElementById("energyModal").style.display = "none";
}

// close when clicking outside
window.onclick = function(e) {
  const modal = document.getElementById("energyModal");
  const mainModal = document.getElementById("modal");

  if (e.target === modal) {
    modal.style.display = "none";
  }
  if (e.target === mainModal) {
    mainModal.style.display = "none";
  }
}

// ===== MAIN POPUP MODAL =====
function openModal(content){
  document.getElementById("modal").style.display = "flex";
  document.getElementById("modal-body").innerHTML = content;
}

function closeModal(){
  document.getElementById("modal").style.display = "none";
}

// ===== DASHBOARD =====
function showDashboard(){
  openModal(`
    <div class="modal-title">📊 Dashboard Summary</div>

    <div class="modal-card">
      ⚡ Total Energy: <span class="highlight"><%= totalEnergy %> kWh</span>
    </div>

    <div class="modal-card">
      🔋 Energy Sold: <span class="highlight"><%= energySold %> kWh</span>
    </div>

    <div class="modal-card">
      💰 Earnings: <span class="highlight">₹ <%= totalEarnings %></span>
    </div>

    <div class="modal-card">
      📈 Progress: <span class="highlight"><%= progress %>%</span>
    </div>
  `);
}
// ===== LISTINGS =====
function showListings(){
  let html = `<div class="modal-title">📊 My Listings</div>`;

  <% if(availableListings.length === 0){ %>
    html += `<p>No listings available ⚡</p>`;
  <% } else { %>

    <% availableListings.forEach(item => { %>
      html += `
        <div class="modal-card">
          ⚡ <b><%= item.energyAmount %> kWh</b><br>
          💰 ₹ <%= item.price %><br>
          🕒 <%= item.time %>
        </div>
      `;
    <% }) %>

  <% } %>

  openModal(html);
}

// ===== TRANSACTIONS =====
function showTransactions(){
  let html = `<div class="modal-title">💳 Transactions</div>`;

  <% if(transactions.length === 0){ %>
    html += `<p>No transactions yet 💸</p>`;
  <% } else { %>

    <% transactions.forEach(t => { %>
      html += `
        <div class="modal-card">
          ⚡ <b><%= t.energyPurchased %> kWh</b><br>
          💰 ₹ <%= t.totalPrice %><br>
          📅 <%= new Date(t.date).toLocaleDateString() %>
        </div>
      `;
    <% }) %>

  <% } %>

  openModal(html);
}

// ===== CARBON =====
function showCarbon(){
  openModal(`
    <div class="modal-title">🌱 Carbon Credits</div>

    <div class="modal-card">
      🌍 CO₂ Saved: <span class="highlight"><%= carbonCredits %> kg</span>
    </div>

    <div class="modal-card">
      🏆 Green Score: <span class="highlight"><%= Math.floor(carbonCredits / 10) %> pts</span>
    </div>

    <div class="modal-card">
      🎖 Badge: 
      <span class="highlight">
        ${
          <%= carbonCredits %> > 50 ? "🌟 Eco Hero" :
          <%= carbonCredits %> > 20 ? "🌿 Green Contributor" :
          "🌱 Beginner"
        }
      </span>
    </div>

    <p style="font-size:12px;color:#666;margin-top:10px;">
      Earn credits by selling renewable energy ⚡
    </p>
  `);
}
</script>
</body>
</html>