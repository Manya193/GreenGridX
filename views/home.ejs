<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>GreenGridX ⚡🌱</title>

<style>
body {
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
  background: #f7fbf9;
}

/* NAVBAR */
.navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 60px;
  background: white;
}

.logo {
  font-size: 22px;
  font-weight: bold;
  color: #0d6b5c;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 25px;
}

.nav-links {
  display: flex;
  gap: 20px;
}

.nav-links a {
  text-decoration: none;
  color: #444;
  font-weight: 500;
}

.auth-buttons {
  display: flex;
  gap: 10px;
}

.auth-buttons button {
  padding: 8px 16px;
  border-radius: 20px;
  border: none;
  background: #ff8c1a;
  color: white;
  cursor: pointer;
}

/* HERO */
.hero {
  display: flex;
  align-items: center;
  max-width: 1200px;
  margin: auto;
  padding: 80px 20px;
}

/* LEFT TEXT */
.hero-text {
  flex: 1;
  padding-bottom:70px;
}

.hero-text h1 {
  font-size: 46px;
  margin: 0;
  color: #0d6b5c;
}

.hero-text h2 {
  margin-top: 10px;
  font-weight: normal;
  color: #6a9f96;
}

.hero-text p {
  margin-top: 15px;
  color: #555;
  line-height: 1.6;
  max-width: 400px;
}

/* BUTTON */
.register-btn {
  margin-top: 20px;
  padding: 12px 24px;
  border-radius: 25px;
  border: none;
  background: #0d6b5c;
  color: white;
  font-weight: bold;
  cursor: pointer;
}

/* RIGHT IMAGE (IMPORTANT FIX) */
.hero-image {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.hero-image img {
  width: 100%;
  max-width: 550px;
}
.footer {
  position: fixed;   /* KEY PART */
  bottom: 0;
  left: 0;
  width: 100%;

  background: #0f3d4c;
  color: white;

  text-align: center;
  padding: 10px;
  font-size: 12px;
}
/* ---------------- HOVER EFFECTS ---------------- */

/* NAV LINKS HOVER */
.nav-links a {
  transition: all 0.3s ease;
}

.nav-links a:hover {
  transform: translateY(-1px);
}

/* BUTTON HOVER */
.auth-buttons button,
.register-btn {
  transition: all 0.3s ease;
}

.auth-buttons button:hover,
.register-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 12px rgba(0,0,0,0.15);
}



/* ---------------- SUBTLE ANIMATIONS ---------------- */

/* Fade in whole page */
body {
  animation: fadeIn 0.8s ease;
}

/* Text slide up */
.hero-text {
  animation: slideUp 0.9s ease;
}

/* Image fade */
.hero-image img {
  animation: fadeIn 1.2s ease;
}

/* KEYFRAMES */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    transform: translateY(25px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}
/* MODAL BACKGROUND */
.modal {
  display: none;   
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;

  background: rgba(0,0,0,0.5);

  justify-content: center;
  align-items: center;

  padding: 20px;   
  box-sizing: border-box;
}

/* MODAL BOX */
.modal-content {
  background: white;
  padding: 40px 60px 40px 40px;
  border-radius: 15px;
  width: 320px;
  margin:auto;
  text-align: center;
  position: relative; 
}

.modal-content select {
  width: 100%;
  padding: 10px;
  margin: 10px 0;
  border-radius: 8px;
  border: 1px solid #ccc;
}

/* CLOSE BUTTON */
.close-btn {
  position: absolute;
  right: 20px;
  top: 10px;
  font-size: 20px;
  cursor: pointer;
}

/* INPUTS */
.modal-content input {
  width: 100%;
  padding: 10px;
  margin: 10px 0;
  border-radius: 8px;
  border: 1px solid #ccc;
}

/* BUTTON */
.modal-content button {
  width: 100%;
  padding: 10px;
  border-radius: 20px;
  border: none;
  background: #0d6b5c;
  color: white;
  cursor: pointer;
}

/* SWITCH TEXT */
#switchText span {
  color: #0d6b5c;
  cursor: pointer;
  font-weight: bold;
}
/* SECTIONS */
.section {
  padding: 60px 80px;
  text-align: center;
}

.section h2 {
  color: #0d6b5c;
  margin-bottom: 15px;
}

.section p {
  color: #555;
  max-width: 600px;
  margin: auto;
  line-height: 1.6;
}

/* LIGHT BG */
.section.light {
  background: #f0fffb;
}

/* SERVICES */
.services {
  display: flex;
  gap: 20px;
  margin-top: 25px;
  justify-content: center;
  flex-wrap: wrap;
}

.service-box {
  background: white;
  padding: 20px;
  border-radius: 10px;
  width: 250px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  transition: 0.3s;
}

.service-box:hover {
  transform: translateY(-5px);
}

/* SMOOTH SCROLL */
html {
  scroll-behavior: smooth;
}
</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
  <div class="logo">GreenGridX ⚡🌱</div>

  <div class="nav-right">

    <div class="nav-links">
      <a href="#">Home</a>
<a href="#about">About</a>
<a href="#services">Services</a>
<a href="#contact">Contact</a>
    </div>

    <div class="auth-buttons">
     <button onclick="openLogin()">Login</button>
<button onclick="openSignup()">Sign Up</button>
    </div>

  </div>
</div>

<!-- HERO -->
<div class="hero">

  <!-- LEFT -->
  <div class="hero-text">
    <h1>Green Energy⚡</h1>
    <h2>AI-powered marketplace</h2>

    <p>
      Buy and sell renewable power locally using intelligent pricing.
      GreenGridX helps reduce energy waste and build a smarter grid.
    </p>

    <button class="register-btn" onclick="openSignup()">Get Started 🚀</button>
  </div>

  <!-- RIGHT -->
  <div class="hero-image">
    <img src="/images/energy.png" alt="energy">
  </div>

</div>
<!-- ABOUT -->
<section id="about" class="section">
  <h2>About GreenGridX 🌱</h2>
  <p>
    GreenGridX is a smart energy marketplace that connects local producers and buyers.
    Our platform uses AI to optimize pricing, reduce energy waste, and promote sustainable energy usage.
  </p>
</section>

<!-- SERVICES -->
<section id="services" class="section light">
  <h2>Our Services ⚡</h2>

  <div class="services">

    <div class="service-box">
      <h3>⚡ Energy Marketplace</h3>
      <p>Buy and sell renewable energy in real-time.</p>
    </div>

    <div class="service-box">
      <h3>🤖 AI Insights</h3>
      <p>Get smart predictions for demand and pricing.</p>
    </div>

    <div class="service-box">
      <h3>🌱 Carbon Credits</h3>
      <p>Earn rewards for using clean energy.</p>
    </div>

  </div>
</section>

<!-- CONTACT -->
<section id="contact" class="section">
  <h2>Contact Us 📞</h2>

  <p>Email: support@greengridx.com</p>
  <p>Phone: +91 9901992638</p>

</section>
<div class="footer">
  © 2026 GreenGridX — Smart energy for a sustainable future ⚡
</div>
<!-- MODAL BACKGROUND -->
<div id="modal" class="modal">

  <div class="modal-content">

    <span class="close-btn" onclick="closeModal()">&times;</span>

    <h2 id="modalTitle">Sign Up</h2>

    <div id="errorBox" style="color:red; font-size:13px; margin-bottom:10px;"></div>

    <form id="modalForm" method="POST" action="/register" autocomplete="off">

      <input type="text" style="display:none">
  <input type="password" style="display:none">

      <input type="text" name="name" placeholder="Name" id="nameField" required />

      <input type="email" name="email" placeholder="Enter your Email" autocomplete="off" required />

      <input type="password" name="password" placeholder="Password" autocomplete="new-password" required />

      <select name="role" id="roleField" required>
        <option value="producer">Producer</option>
        <option value="buyer">Buyer</option>
      </select>

      <input type="text" name="location" placeholder="Location" id="locationField" required />

      <button type="submit">Submit</button>
    </form>

    <p id="switchText">
      Already have an account?
      <span onclick="openLogin()">Login</span>
    </p>

  </div>

</div>

  </div>

</div>

<script>
function openLogin() {
  const form = document.getElementById("modalForm");

  document.getElementById("modal").style.display = "flex";
  document.getElementById("modalTitle").innerText = "Login";

  form.action = "/login";
  form.method = "POST";

  form.reset(); 

const name = document.getElementById("nameField");
const role = document.getElementById("roleField");
const location = document.getElementById("locationField");

name.style.display = "none";
role.style.display = "none";
location.style.display = "none";

name.removeAttribute("required");
role.removeAttribute("required");
location.removeAttribute("required");

  document.getElementById("switchText").innerHTML =
    `Don't have an account? <span onclick="openSignup()">Sign Up</span>`;
}

function openSignup() {
  const form = document.getElementById("modalForm");

  document.getElementById("modal").style.display = "flex";
  document.getElementById("modalTitle").innerText = "Sign Up";

  form.action = "/register";
  form.method = "POST";

  form.reset(); // 🔥 ADD THIS

const name = document.getElementById("nameField");
const role = document.getElementById("roleField");
const location = document.getElementById("locationField");

name.style.display = "block";
role.style.display = "block";
location.style.display = "block";


name.setAttribute("required", true);
role.setAttribute("required", true);
location.setAttribute("required", true);

  document.getElementById("switchText").innerHTML =
    `Already have an account? <span onclick="openLogin()">Login</span>`;
}


function closeModal() {
  document.getElementById("modal").style.display = "none";
}

/* CLICK OUTSIDE TO CLOSE */
window.onclick = function(event) {
  const modal = document.getElementById("modal");
  if (event.target === modal) {
    modal.style.display = "none";
  }
};

// show error from URL
window.onload = function () {
  const params = new URLSearchParams(window.location.search);
  const error = params.get("error");

  if (error) {
    document.getElementById("modal").style.display = "flex";
    document.getElementById("errorBox").innerText = error;

    openLogin();

    
    window.history.replaceState({}, document.title, "/");
  }
};

</script>
</body>
</html>